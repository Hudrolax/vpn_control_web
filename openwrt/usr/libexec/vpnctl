#!/bin/sh
# vpnctl - thin control plane for the corporate VPN on OpenWrt.
# Every subcommand prints a single JSON object; mutations take the global
# flock. See ~/code/vpn_control_web (git) for the source of truth.

LIB="/usr/lib/vpn-control"
. "$LIB/common.sh"
. "$LIB/parser.sh"
. "$LIB/checker.sh"
. "$LIB/renderer.sh"
. "$LIB/worker.sh"

ensure_dirs

cmd_status() {
  _state="$(state_json)"
  _sel="$(printf '%s' "$_state" | jq -r '.selected // ""')"
  _servers="$(servers_json)"
  _checks="$(checks_json)"
  _runtime="$(runtime_get)"
  _busy=null
  if ! lock_is_free; then
    _busy="$(printf '%s' "$_runtime" | jq '.busy // "unknown"')"
  fi
  jq -cn \
    --argjson state "$_state" \
    --argjson servers "$_servers" \
    --argjson checks "$_checks" \
    --argjson runtime "$_runtime" \
    --argjson busy "$_busy" \
    --arg sel "$_sel" \
    --arg xray "$(service_state "$XRAY_SERVICE")" \
    --arg singbox "$(service_state "$SINGBOX_SERVICE")" \
    --arg pbr "$(pbr_state)" \
    --argjson last_refresh "$(last_refresh_ts)" \
    '{
      ok: true,
      enabled: $state.enabled,
      mode: $state.mode,
      selected: (if $sel == "" then null else
        ($servers | map(select(.id == $sel)) | .[0]
          // {id: $sel, name: $sel, address: null}
        | {id, name, address}) end),
      selected_health: (if $sel == "" then null else
        ($checks[$sel] // {status: "unchecked", latency_ms: null, last_checked: null}
        | {status, latency_ms, last_checked}) end),
      subscription: {
        last_refresh: (if $last_refresh == 0 then null else $last_refresh end),
        server_count: ($servers | length),
        last_error: ($runtime.subscription_error // null)
      },
      services: {xray: $xray, singbox: $singbox, pbr: $pbr},
      busy: $busy,
      warning: ($runtime.warning // null),
      legacy_state: ($state.legacy // false),
      version: 1
    }'
}

cmd_list() {
  _sel="$(state_json | jq -r '.selected // ""')"
  jq -cn --argjson servers "$(servers_json)" --argjson checks "$(checks_json)" --arg sel "$_sel" \
    '{ok: true, servers: [$servers[] |
      . + ($checks[.id] // {status: "unchecked", latency_ms: null, last_error: null, last_checked: null})
      + {selected: (.id == $sel)}]}'
}

cmd_logs() {
  _n="${1:-50}"
  echo "$_n" | grep -Eq '^[0-9]{1,3}$' || fail bad_args "logs limit must be 1-999"
  if [ -f "$OPLOG_FILE" ]; then
    tail -n "$_n" "$OPLOG_FILE" | jq -cs '{ok: true, entries: reverse}'
  else
    jq -cn '{ok: true, entries: []}'
  fi
}

cmd_refresh() {
  acquire_lock
  runtime_set '{"busy": "refresh"}'
  _force=""
  [ "$1" = "--force" ] && _force="force"
  _out="$(do_refresh "$_force")" || { runtime_set '{"busy": null}'; exit 1; }
  runtime_set '{"busy": null}'
  printf '%s\n' "$_out"
}

cmd_check() {
  _id=""
  _wait=""
  for _a in "$@"; do
    case "$_a" in
      --wait) _wait=1 ;;
      sub-*) _id="$_a" ;;
      *) fail bad_args "unknown check argument: $_a" ;;
    esac
  done
  if [ -n "$_id" ] && ! servers_json | jq -e --arg id "$_id" '.[] | select(.id == $id)' >/dev/null; then
    fail unknown_server "no such server: $_id"
  fi

  if [ -n "$_wait" ]; then
    acquire_lock
    runtime_set '{"busy": "check"}'
    if [ -n "$_id" ]; then check_one "$_id" || true; else check_all; fi
    runtime_set '{"busy": null}'
    oplog check "${_id:-all}"
    cmd_list
    return 0
  fi

  lock_is_free || fail busy "another vpn-control operation is in progress"
  # Detach the actual check; progress is visible via status.busy + checks.json.
  ( VPNCTL_ACTOR="$ACTOR" /usr/libexec/vpnctl check --wait ${_id:+"$_id"} >/dev/null 2>&1 & ) </dev/null >/dev/null 2>&1
  jq -cn --arg id "${_id:-all}" '{ok: true, started: true, target: $id}'
}

cmd_mode() {
  case "$1" in
    auto-sticky|auto-best|manual) : ;;
    *) fail bad_args "mode must be auto-sticky|auto-best|manual" ;;
  esac
  acquire_lock
  _state="$(state_json)"
  save_state "$(printf '%s' "$_state" | jq -r '.enabled')" "$1" \
    "$(printf '%s' "$_state" | jq -r '.selected // ""')"
  oplog mode "$1"
  jq -cn --argjson state "$(state_json)" '{ok: true, state: $state}'
}

cmd_select() {
  _id="$1"
  [ -n "$_id" ] || fail bad_args "select requires a server id"
  servers_json | jq -e --arg id "$_id" '.[] | select(.id == $id)' >/dev/null \
    || fail unknown_server "no such server: $_id"
  acquire_lock
  runtime_set '{"busy": "select"}'
  _state="$(state_json)"
  if [ "$(printf '%s' "$_state" | jq -r '.enabled')" = "true" ]; then
    apply_server "$_id" || { runtime_set '{"busy": null}'; exit 1; }
  fi
  save_state "$(printf '%s' "$_state" | jq -r '.enabled')" \
    "$(printf '%s' "$_state" | jq -r '.mode')" "$_id"
  runtime_set "{\"busy\": null, \"last_switch\": $(now)}"
  oplog select "$_id"
  jq -cn --argjson state "$(state_json)" '{ok: true, state: $state}'
}

cmd_enable() {
  acquire_lock
  runtime_set '{"busy": "enable"}'
  vpn_enable || { runtime_set '{"busy": null}'; exit 1; }
  runtime_set '{"busy": null}'
  jq -cn --argjson state "$(state_json)" '{ok: true, state: $state}'
}

cmd_disable() {
  acquire_lock
  runtime_set '{"busy": "disable"}'
  vpn_disable || { runtime_set '{"busy": null}'; exit 1; }
  runtime_set '{"busy": null}'
  jq -cn --argjson state "$(state_json)" '{ok: true, state: $state}'
}

cmd_cron() {
  # Non-blocking: if something else holds the lock, skip this tick quietly.
  exec 9>"$LOCK_FILE"
  flock -n 9 || { logger -t vpnctl "cron: lock busy, skipping tick"; exit 0; }
  runtime_set '{"busy": "cron"}'
  _out="$(worker_run)"
  _rc=$?
  runtime_set '{"busy": null}'
  printf '%s\n' "$_out"
  exit "$_rc"
}

cmd_render() {
  _sel="$(state_json | jq -r '.selected // ""')"
  [ -n "$_sel" ] || fail no_server "no server selected"
  _out="$TMP_DIR/render-preview.json"
  render_config "$_sel" "$(cfg '.socks_port' 10808)" "$_out" || fail render "render failed for $_sel"
  if [ "$1" = "--dry-run" ]; then
    if [ -s "$XRAY_CONFIG" ] && cmp -s "$_out" "$XRAY_CONFIG"; then
      jq -cn --arg id "$_sel" '{ok: true, id: $id, differs: false}'
    else
      jq -cn --arg id "$_sel" '{ok: true, id: $id, differs: true, preview: "'"$_out"'"}'
    fi
  else
    cat "$_out"
  fi
}

cmd_migrate() {
  acquire_lock
  [ -s "$STATE_FILE" ] && fail already_migrated "state.json already exists; remove it to re-migrate"
  _tag=""
  [ -s "$LEGACY_TAG_FILE" ] && _tag="$(cat "$LEGACY_TAG_FILE")"
  save_state true "auto-sticky" "$_tag"
  if [ ! -s "$SUB_URL_FILE" ]; then
    # Pull the URL out of the legacy script body (SUB_URL="..." line).
    _url="$(sed -n 's/^SUB_URL="\(.*\)"$/\1/p' /usr/libexec/vpn-subscription-manager* 2>/dev/null | head -n 1)"
    [ -n "$_url" ] || fail no_url "cannot extract SUB_URL from legacy script; create $SUB_URL_FILE manually"
    printf '%s\n' "$_url" > "$SUB_URL_FILE"
    chmod 600 "$SUB_URL_FILE"
  fi
  if [ -s "$LEGACY_WORK_DIR/subscription.raw" ] && [ ! -s "$SUB_CACHE" ]; then
    cp "$LEGACY_WORK_DIR/subscription.raw" "$SUB_CACHE"
    chmod 600 "$SUB_CACHE"
    cp "$LEGACY_STAMP_FILE" "$SUB_STAMP" 2>/dev/null || now > "$SUB_STAMP"
  fi
  # Build servers.json/outbounds.json from the cached subscription.
  decode_subscription && build_server_files
  oplog migrate "selected=$_tag"
  jq -cn --argjson state "$(state_json)" --argjson count "$(servers_json | jq 'length')" \
    '{ok: true, state: $state, server_count: $count}'
}

case "$1" in
  status)  cmd_status ;;
  list)    cmd_list ;;
  logs)    shift; cmd_logs "$@" ;;
  refresh) shift; cmd_refresh "$@" ;;
  check)   shift; cmd_check "$@" ;;
  mode)    shift; cmd_mode "$@" ;;
  select)  shift; cmd_select "$@" ;;
  enable)  cmd_enable ;;
  disable) cmd_disable ;;
  cron)    cmd_cron ;;
  render)  shift; cmd_render "$@" ;;
  migrate) cmd_migrate ;;
  *) fail bad_args "usage: vpnctl status|list|logs|refresh|check|mode|select|enable|disable|cron|render|migrate" ;;
esac
