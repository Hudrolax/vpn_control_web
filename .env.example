# SSH access to the OpenWrt vpnctl control plane
OPENWRT_HOST=192.168.253.112
OPENWRT_PORT=22
OPENWRT_USER=root
SSH_KEY_PATH=/app/ssh/id_ed25519
KNOWN_HOSTS_PATH=/app/ssh/known_hosts
SSH_CONNECT_TIMEOUT_SEC=5
SSH_COMMAND_TIMEOUT_SEC=30

# Poller
POLL_INTERVAL_SEC=15

# SQLite latency history
DB_PATH=/app/data/vpn_control.db
HISTORY_RETENTION_DAYS=30

# For local development outside Docker:
# SSH_KEY_PATH=./ssh/id_ed25519
# KNOWN_HOSTS_PATH=./ssh/known_hosts
# DB_PATH=./data/vpn_control.db
